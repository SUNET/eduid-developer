#!/usr/bin/env python3
#
# Revoke a user by eduPersonPrincipalName.
#
# This replaces the user document with just the eppn and a revoked timestamp,
# and removes related documents from auxiliary collections.
#
# Run as:
#
#   run_with_admintools /opt/eduid/db-scripts/revoke-user EPPN
#

import datetime
import sys

from eduid.userdb import User
from eduid.userdb.admin import RawDb, get_argparser


AUX_COLLECTIONS = [
    {"name": "eduid_idp_authninfo.authn_info", "key": "_id"},
    {"name": "eduid_signup.registered", "key": "_id"},
    {"name": "eduid_dashboard.profiles", "key": "_id"},
    {"name": "eduid_dashboard.verifications", "key": "user_oid"},
    {"name": "eduid_tou.consent", "key": "user_id"},
]


def show_user(user: User) -> None:
    print(f"  eppn: {user.eppn}")
    print(f"  user_id: {user.user_id}")
    for identity in user.identities.to_list():
        print(f"  identity: {identity.identity_type.value} {identity.unique_value}")
    for mail in user.mail_addresses.to_list():
        print(f"  mail: {mail.email}")


def revoke_user(db: RawDb, raw_user, user: User, dry_run: bool) -> None:
    for aux in AUX_COLLECTIONS:
        db_name, coll_name = aux["name"].split(".")
        for aux_doc in db.find(db_name, coll_name, {aux["key"]: user.user_id}):
            print(f"  removing from {aux['name']}")
            aux_doc.doc["DELETE_DOCUMENT"] = True
            db.save_with_backup(aux_doc, dry_run=dry_run)

    raw_user.doc = {
        "_id": raw_user.doc["_id"],
        "eduPersonPrincipalName": user.eppn,
        "revoked_ts": datetime.datetime.now(tz=datetime.UTC),
    }
    print("  replacing user document in eduid_am.attributes")
    db.save_with_backup(raw_user, dry_run=dry_run)


def main(args) -> bool:
    db = RawDb(myname="revoke-user")
    dry_run = not args.force
    count = 0

    for raw_user in db.find("eduid_am", "attributes", {"eduPersonPrincipalName": args.eppn}):
        user = User.from_dict(raw_user.doc)
        print(f"Found user:")
        show_user(user)

        if dry_run:
            print("\nDry run - no changes made. Use --force to revoke.")
        else:
            print(f"\nRevoking user {user.eppn}...")
            revoke_user(db, raw_user, user, dry_run=dry_run)
            print("Done.")

        count += 1

    if not count:
        print(f"No user found with eppn {args.eppn}")

    return bool(count > 0)


if __name__ == "__main__":
    parser = get_argparser(description="Revoke a user by eduPersonPrincipalName", eppn=True)
    args = parser.parse_args()

    if main(args):
        sys.exit(0)
    sys.exit(1)
